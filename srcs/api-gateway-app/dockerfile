FROM alpine:3.18

# 1. Install system dependencies (already working)
RUN apk add --no-cache python3 py3-pip netcat-openbsd postgresql-dev gcc musl-dev

# 2. Set the working directory
WORKDIR /app

# 3. COPY the requirements file FIRST!
COPY requirements.txt .

# 4. Now you can install them
RUN pip install --no-cache-dir -r requirements.txt

# 5. Copy the rest of your app code
COPY . .

# 6. Set your command
CMD ["python3", "server.py"]
# Inventory Database (on inventory-vm)
INVENTORY_DB_NAME=movies
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=inventory_pass
INVENTORY_DB_HOST=inventory-database
INVENTORY_DB_PORT=5432

# Billing Database (on billing-vm)
BILLING_DB_NAME=orders
BILLING_DB_USER=billing_user
BILLING_DB_PASSWORD=billing_pass
BILLING_DB_HOST=billing-database
BILLING_DB_PORT=5432

# RabbitMQ (on billing-vm)
RABBITMQ_USER=billing_rmq
RABBITMQ_PASSWORD=billing_rmq_pass
RABBITMQ_HOST=rabbitmq-server
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=billing_queue

# API Ports
INVENTORY_PORT=8080
BILLING_PORT=8081
GATEWAY_PORT=3000

# VM/Local Static IPs (FOR VAGRANT DEPLOYMENT WITH VIRTUALBOX):
# VAGRANT DEPLOYMENT WITH VIRTUALBOX (ACTIVE):
GATEWAY_IP=api-gateway-app
INVENTORY_IP=inventory-app
BILLING_IP=billing-app

    {
      "name": "Billing",
      "item": [
        {
          "name": "POST /api/billing - place order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains message\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "    pm.expect(jsonData.message).to.include('queued');",
                  "});",
                  "",
                  "pm.test(\"Response contains order data\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('order');",
                  "});",
                  "",
                  "pm.test(\"Order has required fields\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.order).to.have.property('user_id');",
                  "    pm.expect(jsonData.order).to.have.property('number_of_items');",
                  "    pm.expect(jsonData.order).to.have.property('total_amount');",
                  "});",
                  "",
                  "pm.test(\"Order values are correct\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.order.user_id).to.equal('audit_user_01');",
                  "    pm.expect(jsonData.order.number_of_items).to.equal('5');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"audit_user_01\",\n  \"number_of_items\": \"5\",\n  \"total_amount\": \"49.99\"\n}"
            },
            "url": {
              "raw": "http://192.168.56.10:3000/api/billing",
              "host": ["192.168.56.10"],
              "protocol": "http",
              "port": "3000",
              "path": ["api", "billing"]
            },
            "description": "Create an order and publish it to RabbitMQ queue.\n\nReturns 200 OK immediately (async processing).\n\nDemonstrates message queue pattern with eventual consistency and durability."
          },
          "response": []
        }
      ],
      "description": "Billing/Order operations published to RabbitMQ (Message Queue pattern)"
    },

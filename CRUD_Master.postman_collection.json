{
  "info": {
    "_postman_id": "crud-master-collection-v1",
    "name": "CRUD Master - Audit Validation Suite",
    "description": "Audit-ready collection for CRUD Master microservices.\n\nFlow:\n- API Gateway is the single client entry point\n- Gateway routes /api/movies requests to Inventory API\n- Billing requests are published asynchronously\n\nInventory endpoints covered:\n- /api/movies: GET, POST, DELETE\n- /api/movies/<id>: GET, PUT, DELETE\n- /api/movies?title=<name>",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "26420322"
  },
  "item": [
    {
      "name": "Movies",
      "item": [
        {
          "name": "POST /api/movies - create movie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has success flag\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response contains movie object\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie).to.be.an('object');",
                  "    pm.expect(jsonData.movie).to.have.property('id');",
                  "    pm.expect(jsonData.movie).to.have.property('title');",
                  "    pm.expect(jsonData.movie).to.have.property('description');",
                  "});",
                  "",
                  "pm.test(\"Movie has correct values\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie.title).to.equal('Arrival');",
                  "    pm.expect(jsonData.movie.description).to.equal('Sci-fi drama about first contact.');",
                  "});",
                  "",
                  "pm.test(\"Movie has auto-generated ID\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie.id).to.be.a('number');",
                  "    pm.expect(jsonData.movie.id).to.be.greaterThan(0);",
                  "    pm.variables.set('movieId', jsonData.movie.id);",
                  "});",
                  "",
                  "pm.test(\"Movie has timestamps\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.movie).to.have.property('created_at');",
                  "    pm.expect(jsonData.movie).to.have.property('updated_at');",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('movieTitle', 'Arrival');",
                  "pm.variables.set('movieDescription', 'Sci-fi drama about first contact.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Arrival\",\n  \"description\": \"Sci-fi drama about first contact.\"\n}"
            },
            "url": {
              "raw": "http://192.168.56.10:3000/api/movies",
              "host": ["192.168.56.10"],
              "protocol": "http",
              "port": "3000",
              "path": ["api", "movies"]
            },
            "description": "Create a new movie in the inventory.\n\nRequired fields:\n- title\n- description"
          },
          "response": []
        },
